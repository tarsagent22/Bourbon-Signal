{
  "name": "bourbon-signal-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Bourbon Signal active-market data engine and site export pipeline.",
  "scripts": {
    "run": "node src/run.mjs",
    "probe": "node src/probe.mjs",
    "bible": "node src/build-bible.mjs",
    "rare": "node src/rare-report.mjs",
    "location": "node src/location-report.mjs",
    "location:bible": "node src/collect-location-bible.mjs",
    "operational": "node src/operational-report.mjs",
    "export:site": "node --max-old-space-size=16384 src/export-site-contract.mjs",
    "repeatability": "node src/repeatability-check.mjs",
    "quality": "node src/quality-audit.mjs",
    "verify:pristine": "npm run export:site && npm run repeatability && npm run export:site && npm run quality && npm test",
    "verify:pa": "node src/verify-pa.mjs",
    "verify:al": "node src/verify-al.mjs",
    "verify:in": "node src/verify-in.mjs",
    "verify:idaho": "node src/verify-idaho-hardening.mjs",
    "verify:ia": "node src/verify-iowa-hardening.mjs",
    "verify:md": "node src/verify-maryland-hardening.mjs",
    "verify:ut": "node src/verify-utah-hardening.mjs",
    "score:in": "node src/score-in-user-reach.mjs",
    "refresh:pa": "npm run fwgs:full && npm run run && npm run operational && npm run export:site && npm run verify:pa",
    "ohlq": "node src/ohlq-browser-collector.mjs",
    "ohlq:discover": "node src/ohlq-browser-collector.mjs --discover",
    "fwgs": "node src/fwgs-browser-collector.mjs",
    "fwgs:full": "node src/fwgs-browser-full.mjs",
    "browser:discover": "node src/browser-source-discovery.mjs",
    "or": "node src/or-browser-collector.mjs",
    "bible-report": "node src/bible-report.mjs",
    "test": "node src/verify.mjs",
    "refresh:site": "node src/refresh-site.mjs",
    "verify:nc": "node src/verify-nc.mjs",
    "score:nc": "node src/score-nc-user-reach.mjs",
    "verify:va": "node src/verify-va.mjs",
    "verify:tn": "node src/verify-tn.mjs",
    "verify:site": "node src/verify-site-contract.mjs"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5"
  }
}
